  <metadata>
    <id>piopulse</id>
    <version>0.1.1</version>
    <title>PioPulse Flasher</title>
    <authors>Wang Yang</authors>
    <owners>Wang-Yang-source</owners>
    <licenseUrl>https://github.com/Wang-Yang-source/piopulse/blob/master/LICENSE</licenseUrl>
